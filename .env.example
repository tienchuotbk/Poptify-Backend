# Poptify Backend — env mau. Copy sang .env va dien gia tri that.
# KHONG commit .env (xem .gitignore). File nay chi chua placeholder.

NODE_ENV=development
PORT=3000

# Shopify (Partner app credentials)
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SCOPES=read_products,write_products
SHOPIFY_API_VERSION=2026-04
APP_URL=https://your-tunnel-url.example.com

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=poptify

# Token encryption (access token at-rest) — chuoi >= 32 ky tu, tach khoi SHOPIFY_API_SECRET
TOKEN_ENCRYPTION_KEY=change-me-32-bytes-min-secret-key
